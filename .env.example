# Whoop API — register at developer.whoop.com
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=

# Telegram — create bot via @BotFather, get chat ID by messaging @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Google Calendar — download credentials.json from Google Cloud Console
# Paste the full JSON as a single line here for GitHub Actions
GCAL_CREDENTIALS=

# Optional: override default port (8000)
PORT=8000
